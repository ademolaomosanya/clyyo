{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022"],
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "ignoreDeprecations": "6.0",
    "baseUrl": ".",
    "paths": {
      "@clyyo/database": ["packages/database/src"],
      "@clyyo/types": ["packages/types/src"],
      "@clyyo/validation": ["packages/validation/src"],
      "@clyyo/ui": ["packages/ui/src"]
    }
  }
}
